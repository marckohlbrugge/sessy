<!DOCTYPE html>
<html class="antialiased">
  <head>
    <title><%= content_for(:title) || "Sessy" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Sessy">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="<%= asset_path("icon.png") %>" type="image/png">
    <link rel="icon" href="<%= asset_path("icon.svg") %>" type="image/svg+xml">
    <link rel="apple-touch-icon" href="<%= asset_path("icon.png") %>">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "vendor/highlight.js/github-dark", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-white text-zinc-900 dark:bg-zinc-950 dark:text-zinc-100">
    <div class="isolate">
      <%= render "layouts/header" %>

      <% if show_auth_warning? %>
        <div class="bg-amber-500/10 text-amber-700 dark:text-amber-400 px-4 py-2 text-center text-sm border-b border-amber-500/20">
          <strong>No auth configured.</strong>
          Set <code class="bg-amber-500/10 px-1">HTTP_AUTH_USERNAME</code> / <code class="bg-amber-500/10 px-1">HTTP_AUTH_PASSWORD</code> to secure this instance.
        </div>
      <% end %>

      <main>
        <%= yield %>
      </main>
    </div>
  </body>
</html>
