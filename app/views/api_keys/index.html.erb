<% content_for :title, "API keys · Sessy" %>

<div class="mx-auto max-w-6xl px-4 py-6 sm:px-6">
  <div class="flex justify-between items-center">
    <h1 class="text-lg font-semibold">API keys</h1>
  </div>

  <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">
    Keys let AI agents and other tools read this account's email data over
    <%= link_to "MCP", mcp_docs_path, class: "underline hover:text-zinc-900 dark:hover:text-zinc-100" %>.
  </p>

  <% if flash[:api_key_token] %>
    <div class="mt-4 border border-emerald-500/30 bg-emerald-500/5 px-3 py-2.5 text-sm">
      <p class="font-medium text-emerald-700 dark:text-emerald-400">API key created. Copy it now &mdash; it won't be shown again.</p>
      <code class="mt-1 block select-all break-all text-zinc-900 dark:text-zinc-100"><%= flash[:api_key_token] %></code>
    </div>
  <% end %>

  <div class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-8">
    <div>
      <%= form_with model: @api_key do |f| %>
        <% if @api_key.errors.any? %>
          <div class="mb-4 py-2 px-3 border border-red-300 dark:border-red-500/30 text-sm text-red-600 dark:text-red-400">
            <ul role="list" class="list-disc list-inside">
              <% @api_key.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="flex gap-2">
          <%= f.text_field :name, class: "w-full border border-zinc-950/10 dark:border-white/10 bg-transparent px-2.5 py-1.5 text-sm focus:outline-none focus:ring-1 focus:ring-zinc-950/20 dark:focus:ring-white/20", placeholder: "e.g., Claude Code, Cursor" %>
          <%= f.submit "Create key", class: "shrink-0 px-2.5 py-1.5 text-sm border border-zinc-950/10 dark:border-white/10 hover:bg-zinc-50 dark:hover:bg-white/5 cursor-pointer" %>
        </div>
      <% end %>

      <% if @api_keys.any? %>
        <table class="mt-6 min-w-full text-sm">
          <thead>
            <tr class="border-b border-zinc-950/10 dark:border-white/10">
              <th class="py-2 pr-3 text-left text-sm font-medium whitespace-nowrap text-zinc-500 dark:text-zinc-400">Name</th>
              <th class="py-2 pr-3 text-left text-sm font-medium whitespace-nowrap text-zinc-500 dark:text-zinc-400">Key</th>
              <th class="py-2 pr-3 text-left text-sm font-medium whitespace-nowrap text-zinc-500 dark:text-zinc-400 hidden sm:table-cell">Last used</th>
              <th class="py-2 text-right text-sm font-medium whitespace-nowrap text-zinc-500 dark:text-zinc-400"></th>
            </tr>
          </thead>
          <tbody>
            <% @api_keys.each do |api_key| %>
              <tr class="border-b border-zinc-950/5 dark:border-white/5">
                <td class="py-2.5 pr-3 font-medium"><%= api_key.name %></td>
                <td class="py-2.5 pr-3 text-zinc-500 dark:text-zinc-400"><code><%= api_key.token_prefix %>&hellip;</code></td>
                <td class="py-2.5 pr-3 text-zinc-500 dark:text-zinc-400 hidden sm:table-cell">
                  <% if api_key.last_used_at %>
                    <%= local_time(api_key.last_used_at, format: "%b %-d, %Y") %>
                  <% else %>
                    <span class="text-zinc-300 dark:text-zinc-600">Never</span>
                  <% end %>
                </td>
                <td class="py-2.5 text-right">
                  <%= button_to "Revoke", api_key_path(api_key), method: :delete,
                        class: "text-sm text-zinc-500 hover:text-red-600 dark:text-zinc-400 dark:hover:text-red-400 cursor-pointer",
                        form: { data: { turbo_confirm: "Revoke this key? Anything using it will stop working immediately." } } %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="mt-6 text-sm text-zinc-400 dark:text-zinc-500">No API keys yet.</p>
      <% end %>
    </div>

    <div class="text-sm text-zinc-500 dark:text-zinc-400 space-y-4">
      <div>
        <h3 class="font-medium text-zinc-900 dark:text-zinc-100">What are these for?</h3>
        <p class="mt-1">An API key authenticates MCP clients like Claude Code, Cursor, and Codex so they can query your sources, events, and stats. Keys are read-only.</p>
      </div>
      <div>
        <h3 class="font-medium text-zinc-900 dark:text-zinc-100">Keep keys secret</h3>
        <p class="mt-1">A key grants read access to all of this account's email data. Revoke any key you no longer use &mdash; revocation takes effect immediately.</p>
      </div>
    </div>
  </div>
</div>
